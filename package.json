{
  "name": "pearops",
  "productName": "PearOps",
  "version": "0.2.0",
  "upgrade": "pear://17pwkcszz18deaccarhrrixhzf1f5ko1b1dz6j3pxhexebutjwzy",
  "description": "PearOps Linux desktop app: local-first P2P incident response with Keet portable identity",
  "license": "MIT",
  "author": "pearops",
  "type": "commonjs",
  "main": "electron/main.js",
  "private": true,
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "start": "npm run build:renderer && electron-forge start -- --no-updates",
    "start:dev": "concurrently -k \"npm:dev\" \"wait-on tcp:5173 && cross-env PEAR_DEV_SERVER_URL=http://127.0.0.1:5173 electron-forge start -- --no-updates\"",
    "build:renderer": "vite build",
    "lint": "node -c electron/main.js && node -c electron/preload.js && node -c src/peer.js && node -c src/identity.js && node -c workers/main.js && node -c src/p2p/room-key.js && node -c src/p2p/blind-peers.js && node -c src/p2p/json-line-socket.js && node -c src/app/settings.js && node -c src/app/local-state.js && node -c src/app/incidents.js && npm run build:renderer",
    "test": "node test/identity.js && node test/state.js && node test/p2p-utils.js && node test/pearops-client.mjs && node test/app-settings.js && node test/local-state.js && node test/incidents.js",
    "smoke": "node test/smoke.js",
    "package": "npm run build:renderer && electron-forge package",
    "make": "npm run build:renderer && electron-forge make"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "b4a": "^1.8.1",
    "blind-peer-cli": "^1.8.0",
    "blind-peering": "^2.4.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "corestore": "^7.11.0",
    "framed-stream": "^1.0.1",
    "graceful-goodbye": "^1.3.3",
    "hypercore": "^11.33.5",
    "hypercore-crypto": "^3.6.1",
    "hyperdrive": "^13.3.2",
    "hyperswarm": "^4.17.0",
    "keet-identity-key": "^3.2.0",
    "lucide-react": "^0.562.0",
    "paparam": "^1.10.0",
    "pear-runtime": "^1.1.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "which-runtime": "^1.3.2"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-deb": "^7.11.1",
    "@electron-forge/maker-dmg": "^7.11.1",
    "@electron-forge/maker-msix": "^7.11.1",
    "@electron-forge/maker-rpm": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@vitejs/plugin-react": "^5.1.2",
    "app-builder-lib": "^26.8.1",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^40.2.1",
    "electron-forge-plugin-prune-prebuilds": "^1.0.0",
    "electron-forge-plugin-universal-prebuilds": "^1.0.0",
    "eslint": "^9.39.2",
    "pear-electron-forge-maker-appimage": "^2.0.0",
    "pear-electron-forge-maker-flatpak": "^0.0.6",
    "pear-electron-forge-maker-snap": "^0.0.10",
    "vite": "^7.3.0",
    "wait-on": "^9.0.3"
  },
  "allowScripts": {
    "electron@40.10.1": true,
    "electron-winstaller": false
  }
